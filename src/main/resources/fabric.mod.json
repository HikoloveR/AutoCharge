{
  "schemaVersion": 1,
  "id": "autocharge",
  "version": "${version}",

  "name": "AutoCharge",
  "description": "Local nickname manager for quickly switching offline accounts from the Minecraft main menu.",
  "icon": "assets/autocharge/icon.png",
  "authors": [
    "HikoloveR"
  ],
  "contact": {
    "homepage": "https://github.com/HikoloveR",
    "sources": "https://github.com/HikoloveR/AutoCharge"
  },

  "license": "All-Rights-Reserved",

  "environment": "client",
  "entrypoints": {
    "client": [
      "fakefun.ru.autocharge.AutoChargeClient"
    ]
  },

      "mixins": [
        "autocharge.mixins.json"
      ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
